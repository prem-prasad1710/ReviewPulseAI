{
  "name": "reviewpulse",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "mongo:local:up": "podman rm -f reviewpulse-mongo-local 2>/dev/null || true && podman run -d --name reviewpulse-mongo-local -p 127.0.0.1:27018:27017 -e MONGO_INITDB_ROOT_USERNAME=localuser -e MONGO_INITDB_ROOT_PASSWORD=localuser docker.io/library/mongo:7",
    "mongo:local:down": "podman rm -f reviewpulse-mongo-local 2>/dev/null || true",
    "mongo:local:compose-up": "sh -c 'cd infra/local-mongo && podman compose -f compose.yml up -d'",
    "mongo:local:compose-down": "sh -c 'cd infra/local-mongo && podman compose -f compose.yml down'"
  },
  "dependencies": {
    "@react-email/components": "^1.0.0",
    "@react-email/render": "^1.0.0",
    "@react-pdf/renderer": "^4.5.1",
    "@sentry/nextjs": "^10.50.0",
    "@types/qrcode": "^1.5.6",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "@vercel/blob": "^2.3.3",
    "@vercel/og": "^0.11.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.0.0",
    "franc-min": "^6.2.0",
    "googleapis": "^150.0.0",
    "lucide-react": "^0.469.0",
    "luxon": "^3.7.2",
    "mongoose": "^8.0.0",
    "next": "16.2.4",
    "next-auth": "^5.0.0-beta.0",
    "next-themes": "^0.4.6",
    "openai": "^4.0.0",
    "qrcode": "^1.5.4",
    "razorpay": "^2.9.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^2.0.0",
    "resend": "^4.0.0",
    "sharp": "^0.34.5",
    "sonner": "^1.7.0",
    "tailwind-merge": "^2.0.0",
    "twilio": "^6.0.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/luxon": "^3.7.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
